# Copy this to a root `.env` file for the dev stack (docker-compose.dev.yml).
# docker compose auto-loads `./.env`. Only the publishable key is needed here;
# everything else has sensible localhost defaults baked into the compose file.
#
# The key is generated by the seed on the first backend start. Get it with:
#   docker exec medusa_postgres_dev psql -U medusa -d medusa -tAc \
#     "select token from api_key where type='publishable'"
# Paste it below, then restart the storefront:
#   docker compose -f docker-compose.dev.yml restart storefront
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_CHANGE_ME
